# compose.yaml bind-mounts host /box/tonic/vault → /data/vault (read-only).
# Path must be inside the container, not the host.
KDBX_PATH=/data/vault/passbolt.kdbx

# Composite key: set password and/or keyfile path inside the container.
KDBX_PASSWORD=
# KDBX_KEYFILE=/data/vault.keyx

# Required to return `password` from kdbx_get_entry (include_password=true).
KDBX_ALLOW_PASSWORD_EXPORT=0

# Secrets / local data
.env

# Calendar app secrets/data
calendar/credentials/*.json
calendar/data/

# Radicale
# - Track config files in radicale/etc
# - Ignore runtime storage (radicale/var) and real credential material (users)
calendar/radicale/var/
calendar/radicale/etc/users
calendar/radicale/**
!/calendar/radicale/etc/default.conf
!/calendar/radicale/etc/rights
!/calendar/radicale/etc/users.example

# Hermes data
hermes/*
!hermes/compose.yaml

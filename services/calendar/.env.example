# Copy to .env and fill in. Compose loads .env from this directory automatically.
# Public HTTPS (nginx): https://<your-host>/calendar/ — see nginx/ssl/README.txt for TLS files.
# Calendar sync: edit config/*.json (see config/README.md); copy from *.json.example.

# Shared Radicale HTTP basic auth (same as radicale/etc/users)
RADICALE_USER=liempo
RADICALE_PASSWORD=change-me

# Seconds between each sync cycle (default 1800 = 30 minutes)
SYNC_INTERVAL_SECONDS=1800

# Radicale HTTP URL for PUT (no trailing slash). Used with collection id from each config JSON.
RADICALE_BASE_URL=http://radicale:5232

# Google OAuth token path in container (optional; normally set per sync-google-* service in compose.yaml):
# GOOGLE_TOKEN_PATH=/config/sync-google-astra-token.json
